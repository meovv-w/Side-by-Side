.private-chat { height: 100vh; background: #eef1f4; overflow: hidden; }.contact-bar { display: flex; align-items: center; gap: 14rpx; height: 100rpx; padding: 0 22rpx; background: #fff; border-bottom: 1rpx solid #dfe5ea; box-sizing: border-box; }.contact-bar > view:nth-child(2) { flex: 1; }.contact-name { font-size: 26rpx; font-weight: 700; }.relation { color: #0e7c66; font-size: 20rpx; }.private-messages { height: calc(100vh - 210rpx - env(safe-area-inset-bottom)); padding: 20rpx 24rpx; box-sizing: border-box; }.privacy-tip { width: fit-content; margin: 0 auto 28rpx; padding: 7rpx 12rpx; background: #dfe5ea; color: #6d7a86; border-radius: 7rpx; font-size: 19rpx; }.private-row { display: flex; margin-bottom: 20rpx; flex-direction: column; align-items: flex-start; }.private-row.mine { align-items: flex-end; }.private-row .bubble { max-width: 72%; padding: 16rpx 20rpx; background: #fff; border-radius: 5rpx 15rpx 15rpx 15rpx; word-break: break-all; }.private-row.mine .bubble { background: #1f6feb; color: #fff; border-radius: 15rpx 5rpx 15rpx 15rpx; }.private-row .caption { margin-top: 4rpx; }.blocked-bar, .private-composer { position: fixed; right: 0; bottom: 0; left: 0; display: flex; align-items: center; justify-content: space-between; min-height: 110rpx; padding: 14rpx 20rpx calc(14rpx + env(safe-area-inset-bottom)); background: #fff; border-top: 1rpx solid #dce2e7; box-sizing: border-box; color: #697783; font-size: 23rpx; }.private-composer { gap: 10rpx; }.private-composer input { height: 70rpx; padding: 0 18rpx; flex: 1; background: #f0f2f4; border-radius: 14rpx; }.private-composer button { margin: 0; }.more { width: 62rpx; height: 62rpx; line-height: 55rpx; padding: 0; border-radius: 50%; background: #e9edf1; color: #46535f; }.send { width: 100rpx; height: 66rpx; line-height: 66rpx; padding: 0; border-radius: 12rpx; background: #1f6feb; color: #fff; font-size: 23rpx; }
