<view class="page">
  <view class="next-hero"><view class="title">下一趟去哪？</view><view class="muted">先记下路线，准备好后发起组队或加入现有队伍</view></view>
  <view class="route-fields"><input placeholder="起点" value="{{form.from}}" data-key="from" bindinput="input"/><view class="route-arrow">→</view><input placeholder="终点" value="{{form.to}}" data-key="to" bindinput="input"/></view>
  <view class="date-grid"><picker mode="date" value="{{form.date}}" start="{{minDate}}" bindchange="date"><view class="picker-field">{{form.date}}</view></picker><picker mode="time" value="{{form.time}}" bindchange="time"><view class="picker-field">{{form.time}}</view></picker></view>
  <textarea class="textarea" placeholder="想去的地方、同行偏好（选填）" value="{{form.note}}" data-key="note" bindinput="input"></textarea>
  <button class="primary-btn save" bindtap="submit">保存行程草稿</button>
  <view class="section-header"><view class="section-title">已保存草稿</view><view class="muted">{{drafts.length}} 条</view></view>
  <view wx:if="{{drafts.length===0}}" class="empty">还没有草稿</view>
  <view wx:for="{{drafts}}" wx:key="_id" class="card draft">
    <view class="draft-status {{item.status}}">{{item.status==='draft'?'草稿':'已发布'}}</view>
    <view class="card-title draft-route">{{item.from}} → {{item.to}}</view><view class="muted">{{item.departAt}}</view>
    <view wx:if="{{item.note}}" class="draft-note">{{item.note}}</view>
    <view wx:if="{{item.status==='draft'}}" class="draft-actions"><button class="secondary-btn small-btn" data-id="{{item._id}}" bindtap="findMatches">找同路队伍</button><button class="primary-btn small-btn" data-id="{{item._id}}" bindtap="publish">发起组队</button></view>
  </view>
</view>

<view wx:if="{{matchPanelOpen}}" class="match-mask" catchtap="closeMatches">
  <view class="match-panel" catchtap="noop">
    <view class="match-head"><view><view class="section-title">同路队伍</view><view class="muted">{{selectedDraft.from}} → {{selectedDraft.to}} · 起点 10km 内</view></view><button class="match-close" bindtap="closeMatches">×</button></view>
    <view wx:if="{{matching}}" class="match-empty">正在计算顺路率...</view>
    <view wx:elif="{{matches.length===0}}" class="match-empty">暂时没有符合条件的队伍，可直接发起组队</view>
    <scroll-view wx:else scroll-y class="match-list">
      <view wx:for="{{matches}}" wx:key="_id" class="match-row" data-id="{{item._id}}" bindtap="openMatch">
        <view class="match-main"><view class="card-title">{{item.teamName}}</view><view class="muted">{{item.from}} → {{item.to}}</view><view class="caption">{{item.departAt}} · {{item.seatJoined}}/{{item.seatTotal}}车</view></view>
        <view class="match-rate">{{item.matchRate || 0}}%<text>顺路</text></view>
      </view>
    </scroll-view>
  </view>
</view>
