.next-hero{margin-bottom:20rpx;padding:28rpx;background:#172b4d;color:#fff;border-radius:16rpx}.next-hero .muted{color:#c5d1df}.route-fields{display:grid;grid-template-columns:1fr 50rpx 1fr;align-items:center;margin-bottom:16rpx}.route-fields input{height:84rpx;padding:0 18rpx;background:#fff;border:1rpx solid #d9e0e6;border-radius:14rpx}.route-arrow{text-align:center;color:#1f6feb;font-size:31rpx}.date-grid{display:grid;grid-template-columns:1fr 1fr;gap:14rpx}.save{width:100%}.draft{position:relative}.draft-status{position:absolute;top:20rpx;right:20rpx;padding:5rpx 10rpx;border-radius:8rpx;background:#eaf2ff;color:#1558b0;font-size:20rpx}.draft-status.published{background:#e4f6ef;color:#087f5b}.draft-note{margin:12rpx 0;color:#53616d}.draft button{width:220rpx;margin:16rpx 0 0}
