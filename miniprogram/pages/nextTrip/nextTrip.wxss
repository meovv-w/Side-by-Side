.next-hero{margin-bottom:20rpx;padding:28rpx;background:#172b4d;color:#fff;border-radius:16rpx}.next-hero .muted{color:#c5d1df}.route-fields{display:grid;grid-template-columns:1fr 50rpx 1fr;align-items:center;margin-bottom:16rpx}.route-fields input{height:84rpx;padding:0 18rpx;background:#fff;border:1rpx solid #d9e0e6;border-radius:14rpx}.route-arrow{text-align:center;color:#1f6feb;font-size:31rpx}.date-grid{display:grid;grid-template-columns:1fr 1fr;gap:14rpx}.save{width:100%}.draft{position:relative}.draft-route{max-width:470rpx;padding-right:90rpx}.draft-status{position:absolute;top:20rpx;right:20rpx;padding:5rpx 10rpx;border-radius:8rpx;background:#eaf2ff;color:#1558b0;font-size:20rpx}.draft-status.converted,.draft-status.published{background:#e4f6ef;color:#087f5b}.draft-note{margin:12rpx 0;color:#53616d}.draft-actions{display:grid;grid-template-columns:1fr 1fr;gap:12rpx;margin-top:18rpx}.draft-actions button{width:100%;margin:0}.match-mask{position:fixed;z-index:50;inset:0;display:flex;align-items:flex-end;background:rgba(17,27,38,.46)}.match-panel{width:100%;max-height:76vh;padding:26rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));border-radius:16rpx 16rpx 0 0;background:#fff;box-sizing:border-box}.match-head{display:flex;align-items:flex-start;justify-content:space-between;gap:20rpx}.match-close{width:62rpx;height:62rpx;line-height:58rpx;margin:0;padding:0;border:0;border-radius:50%;background:#eef1f4;color:#394754;font-size:38rpx}.match-list{max-height:56vh;margin-top:20rpx}.match-row{display:grid;grid-template-columns:minmax(0,1fr) 98rpx;align-items:center;gap:16rpx;padding:20rpx 0;border-bottom:1rpx solid #edf0f2}.match-main{min-width:0}.match-main .card-title,.match-main .muted{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.match-rate{color:#087f5b;text-align:right;font-size:30rpx;font-weight:750}.match-rate text{display:block;color:#71808f;font-size:19rpx;font-weight:500}.match-empty{padding:70rpx 10rpx;color:#71808f;text-align:center}
