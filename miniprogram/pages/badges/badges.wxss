.badge-summary{margin-bottom:24rpx;padding:28rpx;background:#172b4d;color:#fff;border-radius:16rpx}.badge-summary .muted{color:#c4d1df}.badge-grid{display:grid;grid-template-columns:1fr 1fr;gap:14rpx}.badge-card{padding:26rpx 18rpx;background:#fff;border:1rpx solid #e0e6eb;border-radius:16rpx;text-align:center}.badge-card.locked{opacity:.55}.badge-medal{display:flex;align-items:center;justify-content:center;width:88rpx;height:88rpx;margin:0 auto 14rpx;border-radius:50%;background:#fff2cf;color:#a05a00;font-size:30rpx;font-weight:750}.locked .badge-medal{background:#e8ecef;color:#6e7b87}.badge-card .muted{min-height:72rpx;margin:7rpx 0 12rpx;font-size:21rpx}
