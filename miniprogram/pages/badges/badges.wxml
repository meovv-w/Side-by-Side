<view class="page"><view class="badge-summary"><view class="title">我的勋章</view><view class="muted">每一枚都来自真实同行记录</view></view><view class="badge-grid"><view wx:for="{{badges}}" wx:key="name" class="badge-card {{item.owned?'':'locked'}}"><view class="badge-medal">{{item.owned?'章':'锁'}}</view><view class="card-title">{{item.name}}</view><view class="muted">{{item.desc}}</view><view class="tag {{item.owned?'warning':'neutral'}}">{{item.owned?'已获得':'待解锁'}}</view></view></view></view>
