.invite-hero{padding:38rpx 26rpx;background:#172b4d;color:#fff;border-radius:16rpx;text-align:center}.invite-label{color:#a9c7ff;font-size:22rpx}.invite-code{margin:13rpx 0 8rpx;font-family:monospace;font-size:54rpx;font-weight:800;letter-spacing:8rpx}.invite-sub{color:#c3cfdd;font-size:22rpx}.share-button{width:330rpx;height:76rpx;line-height:76rpx;margin:26rpx auto 0;border-radius:14rpx;background:#1f6feb;color:#fff;font-size:25rpx}.reward-progress{margin-top:18rpx}.reward-progress .progress{margin:18rpx 0}.reward-row{display:flex;align-items:center;gap:14rpx;min-height:82rpx;border-top:1rpx solid #edf0f2}.reward-check{display:flex;align-items:center;justify-content:center;width:48rpx;height:48rpx;border-radius:50%;background:#edf0f2;color:#6c7985;font-size:21rpx}.reward-check.done{background:#e4f6ef;color:#087f5b}.reward-main{flex:1}.invite-record{display:flex;align-items:center;gap:14rpx}.record-main{flex:1}.invite-rule{padding:20rpx;background:#fff4d6;border-radius:14rpx;color:#73501c;font-size:22rpx;line-height:1.7}
