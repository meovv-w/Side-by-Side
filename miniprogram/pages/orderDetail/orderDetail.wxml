<view class="page order-detail" wx:if="{{order}}">
  <view class="status-card {{order.status === 'used' ? 'used' : ''}}"><view class="status-icon">{{order.status === 'used' ? '✓' : '码'}}</view><view><view class="status-title">{{order.statusText}}</view><view class="status-sub">{{order.status === 'paid' ? '请到店向商家出示核销码' : order.status === 'used' ? '已完成核销，感谢使用' : '请留意退款进度'}}</view></view></view>
  <view wx:if="{{order.status === 'paid' && order.refundStatus === 'none'}}" class="code-card" bindtap="copyCode"><view class="muted">6 位核销码</view><view class="digits"><text wx:for="{{codeDigits}}" wx:key="index">{{item}}</text></view><view class="caption">点击复制核销码 · 请勿提前告知他人</view></view>
  <view wx:if="{{order.refundStatus === 'pending'}}" class="refund-status"><view class="card-title">退款审核中</view><view class="muted">申请已提交，审核通过后将按原支付方式退回。</view></view>
  <view class="card"><view class="row"><view><view class="card-title">{{order.title}}</view><view class="muted">{{order.merchantName}}</view></view><text class="section-link" bindtap="navigate">导航</text></view><view class="divider"></view><view class="detail-row"><text>订单编号</text><text>{{order._id}}</text></view><view class="detail-row"><text>下单时间</text><text>{{order.createdAt}}</text></view><view class="detail-row"><text>有效期至</text><text>{{order.expiresAt || '已使用'}}</text></view><view wx:if="{{order.verifiedAt}}" class="detail-row"><text>核销时间</text><text>{{order.verifiedAt}}</text></view></view>
  <view class="card amount-card"><view class="detail-row"><text>商品金额</text><text>¥{{order.originAmount}}</text></view><view class="detail-row"><text>优惠抵扣</text><text>-¥{{order.discountAmount || 0}}</text></view><view class="detail-row total"><text>实付</text><text>¥{{order.amount}}</text></view></view>
  <view class="action-grid"><button class="secondary-btn" bindtap="support">联系客服</button><button wx:if="{{order.status === 'paid' && order.refundStatus === 'none'}}" class="refund-button" bindtap="refund">申请退款</button></view>
</view>
<view wx:else class="empty">正在加载订单</view>
