.status-card { display: flex; align-items: center; gap: 18rpx; margin: -24rpx -24rpx 20rpx; padding: 34rpx 26rpx; background: #172b4d; color: #fff; }.status-card.used { background: #0e7c66; }.status-icon { display: flex; align-items: center; justify-content: center; width: 76rpx; height: 76rpx; border-radius: 50%; background: rgba(255,255,255,.16); font-size: 28rpx; font-weight: 700; }.status-title { font-size: 34rpx; font-weight: 750; }.status-sub { margin-top: 3rpx; color: rgba(255,255,255,.72); font-size: 22rpx; }.code-card { margin-bottom: 20rpx; padding: 28rpx 20rpx; background: #fff; border: 1rpx solid #e0e6eb; border-radius: 16rpx; text-align: center; }.digits { display: flex; justify-content: center; gap: 10rpx; margin: 20rpx 0 14rpx; }.digits text { display: flex; align-items: center; justify-content: center; width: 72rpx; height: 90rpx; border: 2rpx solid #cbd5df; border-radius: 12rpx; background: #f7f9fa; font-family: monospace; font-size: 41rpx; font-weight: 750; }.refund-status { margin-bottom: 20rpx; padding: 22rpx; background: #fff4d6; border: 1rpx solid #f0d28c; border-radius: 16rpx; }.detail-row { display: flex; justify-content: space-between; margin-top: 15rpx; color: #677582; font-size: 23rpx; }.detail-row text:last-child { max-width: 430rpx; color: #26323d; text-align: right; word-break: break-all; }.amount-card .detail-row:first-child { margin-top: 0; }.detail-row.total { margin-top: 18rpx; padding-top: 17rpx; border-top: 1rpx solid #e7ebef; font-size: 28rpx; font-weight: 700; }.detail-row.total text:last-child { color: #d94841; }.action-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; }.refund-button { height: 80rpx; line-height: 80rpx; margin: 0; border: 1rpx solid #d94841; border-radius: 16rpx; background: #fff; color: #c83c32; font-size: 27rpx; }
.verify-qr { display: block; width: 260rpx; height: 260rpx; margin: 18rpx auto; }
