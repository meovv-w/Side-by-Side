.detail-page { min-height: 100vh; background: #f3f5f7; }.product-visual { position: relative; display: flex; height: 390rpx; padding: 42rpx; flex-direction: column; justify-content: flex-end; background: linear-gradient(145deg, #243b53 0%, #0e7c66 58%, #f59e0b 150%); color: #fff; box-sizing: border-box; }.visual-category { position: absolute; top: 28rpx; left: 28rpx; padding: 7rpx 12rpx; border: 1rpx solid rgba(255,255,255,.4); border-radius: 8rpx; font-size: 21rpx; }.visual-title { max-width: 620rpx; font-size: 43rpx; font-weight: 800; line-height: 1.25; }.visual-sub { margin-top: 8rpx; color: rgba(255,255,255,.78); font-size: 24rpx; }.content { padding: 0 22rpx 140rpx; }.deal-summary { margin: -1rpx -22rpx 0; padding: 24rpx 24rpx 22rpx; background: #fff; }.price-row { display: flex; align-items: baseline; gap: 10rpx; }.price { color: #d94841; font-size: 47rpx; font-weight: 850; }.origin { color: #9aa4ad; text-decoration: line-through; }.save { padding: 5rpx 9rpx; border-radius: 7rpx; background: #ffebe9; color: #c83c32; font-size: 20rpx; }.deal-summary .title { margin-top: 8rpx; }.merchant { margin-top: 9rpx; color: #667583; font-size: 23rpx; }.countdown-row { display: flex; justify-content: space-between; margin: 0 -22rpx 18rpx; padding: 14rpx 24rpx; background: #fff4d6; color: #89510a; font-size: 22rpx; }.progress-card { margin-top: 0; }.progress-card .progress { margin: 18rpx 0; }.avatars { display: flex; }.avatars .avatar { margin-right: -10rpx; border: 3rpx solid #fff; }.avatars .more { background: #edf0f2; color: #5d6975; }
.tier { display: flex; align-items: center; justify-content: space-between; min-height: 84rpx; padding: 0 6rpx; border-bottom: 1rpx solid #edf0f2; opacity: .58; }.tier.reached { opacity: 1; }.tier-people { margin-right: 10rpx; font-weight: 650; }.tier-price { display: block; color: #d94841; font-size: 29rpx; font-weight: 750; text-align: right; }.tier-save { display: block; color: #7c8995; font-size: 19rpx; }.description { color: #4f5d69; line-height: 1.7; }.rule { display: flex; align-items: center; gap: 12rpx; margin-top: 14rpx; color: #53616d; font-size: 23rpx; }.rule text { display: flex; align-items: center; justify-content: center; width: 36rpx; height: 36rpx; border-radius: 50%; background: #eaf2ff; color: #1558b0; font-size: 20rpx; }.deal-footer { grid-template-columns: 1fr 2fr; }.buy-button { background: #d94841; }
.mask { position: fixed; z-index: 30; inset: 0; background: rgba(17,27,35,.5); }.checkout-sheet { position: fixed; z-index: 31; right: 0; bottom: 0; left: 0; max-height: 82vh; padding: 28rpx 24rpx calc(24rpx + env(safe-area-inset-bottom)); overflow-y: auto; background: #fff; border-radius: 20rpx 20rpx 0 0; box-sizing: border-box; }.close { width: 60rpx; height: 60rpx; line-height: 56rpx; margin: 0; padding: 0; border-radius: 50%; background: #edf0f2; color: #53606c; font-size: 33rpx; }.checkout-product { display: flex; align-items: center; justify-content: space-between; margin-top: 18rpx; padding: 20rpx; background: #f5f7f9; border-radius: 14rpx; }.coupon-choice { display: flex; align-items: center; justify-content: space-between; min-height: 78rpx; padding: 10rpx 16rpx; border: 1rpx solid #e0e6eb; border-radius: 12rpx; margin-bottom: 10rpx; }.coupon-choice.selected { border-color: #1f6feb; background: #f4f8ff; }.coupon-amount { color: #d94841; font-weight: 700; }.pay-summary { margin-top: 18rpx; padding-top: 12rpx; border-top: 1rpx solid #e7ebef; }.pay-summary > view { display: flex; justify-content: space-between; margin-top: 12rpx; color: #677582; font-size: 24rpx; }.pay-summary .pay-total { color: #17202a; font-size: 29rpx; font-weight: 700; }.pay-total text:last-child { color: #d94841; }.pay-button { width: 100%; margin-top: 20rpx; background: #d94841; }
