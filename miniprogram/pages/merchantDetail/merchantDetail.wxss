.merchant-page{min-height:100vh;background:#f3f5f7}.merchant-head{display:flex;align-items:center;gap:18rpx;padding:36rpx 28rpx;background:#172b4d;color:#fff}.merchant-mark{display:flex;width:92rpx;height:92rpx;align-items:center;justify-content:center;border-radius:14rpx;background:#fff4d6;color:#89510a;font-size:34rpx;font-weight:750}.merchant-main{min-width:0;flex:1}.merchant-meta{margin-top:6rpx;color:#c7d3df;font-size:23rpx}.merchant-content{min-height:auto}.merchant-info{padding:22rpx;background:#fff;border:1rpx solid #dfe5ea;border-radius:14rpx}.info-row{display:flex;justify-content:space-between;gap:24rpx;padding:13rpx 0;border-bottom:1rpx solid #edf0f2;color:#71808f}.info-row text:last-child{max-width:470rpx;color:#25313c;text-align:right}.merchant-description{padding:18rpx 0;color:#53616d;line-height:1.7}.info-actions{display:grid;grid-template-columns:1fr 1fr;gap:12rpx;margin-top:16rpx}.rescue-band{margin-top:18rpx;padding:20rpx;border:1rpx solid #e8c883;border-radius:12rpx;background:#fff8e5;color:#745118}.rescue-band .card-title{margin-bottom:6rpx}.deal-row{display:grid;grid-template-columns:130rpx minmax(0,1fr) 24rpx;align-items:center;gap:16rpx;margin-bottom:14rpx;padding:16rpx;background:#fff;border:1rpx solid #dfe5ea;border-radius:14rpx}.deal-row image{width:130rpx;height:104rpx;border-radius:8rpx;background:#e6eaed}.deal-main{min-width:0}.deal-main .card-title{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.deal-price{margin-top:8rpx;color:#c83c32;font-size:27rpx;font-weight:750}
