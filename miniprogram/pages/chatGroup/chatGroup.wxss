.chat-page {
  padding-bottom: 130rpx;
}

.messages {
  height: calc(100vh - 180rpx);
}

.message {
  margin-bottom: 16rpx;
}

.name {
  font-weight: 700;
}

.composer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 18rpx 24rpx;
  background: #ffffff;
  border-top: 1rpx solid #e5ece9;
}

.composer-input {
  flex: 1;
  margin-bottom: 0;
}

.send {
  width: 150rpx;
}
