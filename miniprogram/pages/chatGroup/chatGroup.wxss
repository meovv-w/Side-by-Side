.chat-page { height: 100vh; background: #eef1f4; overflow: hidden; }
.team-header { display: flex; align-items: center; justify-content: space-between; height: 108rpx; padding: 0 24rpx; background: #fff; border-bottom: 1rpx solid #dde3e8; box-sizing: border-box; }.team-title { font-size: 29rpx; font-weight: 700; }.team-meta { color: #71808f; font-size: 21rpx; }.team-state { padding: 7rpx 12rpx; border-radius: 8rpx; background: #e4f6ef; color: #087f5b; font-size: 21rpx; }
.message-list { height: calc(100vh - 218rpx - env(safe-area-inset-bottom)); padding: 20rpx 22rpx; box-sizing: border-box; }.system-tip, .system-message { width: fit-content; max-width: 600rpx; margin: 0 auto 20rpx; padding: 8rpx 13rpx; border-radius: 8rpx; background: #dfe5ea; color: #6b7884; font-size: 20rpx; text-align: center; }.system-message { margin-bottom: 18rpx; }
.message-row { display: flex; align-items: flex-start; gap: 12rpx; margin-bottom: 22rpx; }.message-row.mine { flex-direction: row-reverse; }.message-avatar { display: flex; align-items: center; justify-content: center; width: 66rpx; height: 66rpx; border-radius: 14rpx; background: #dce9ff; color: #1558b0; font-size: 23rpx; font-weight: 700; }.message-body { max-width: 74%; }.message-name { margin-bottom: 5rpx; color: #7c8995; font-size: 19rpx; }.message-row.mine .message-name { text-align: right; }.bubble { padding: 16rpx 18rpx; background: #fff; border-radius: 5rpx 15rpx 15rpx 15rpx; color: #27333e; font-size: 26rpx; word-break: break-all; }.message-row.mine .bubble { background: #1f6feb; color: #fff; border-radius: 15rpx 5rpx 15rpx 15rpx; }.image-bubble { padding: 7rpx; background: #fff !important; }.image-bubble image { display: block; width: 320rpx; height: 240rpx; border-radius: 10rpx; }.special-bubble { display: flex; align-items: center; gap: 12rpx; min-width: 300rpx; background: #fff !important; color: #27333e !important; }.special-icon { display: flex; align-items: center; justify-content: center; width: 55rpx; height: 55rpx; border-radius: 11rpx; background: #e4f6ef; color: #087f5b; font-weight: 700; }.groupbuy-bubble .special-icon { background: #ffebe9; color: #c83c32; }.bubble-meta { max-width: 350rpx; margin-top: 2rpx; overflow: hidden; color: #71808f; font-size: 20rpx; text-overflow: ellipsis; white-space: nowrap; }.voice-bubble { min-width: 170rpx; }
.composer { position: fixed; right: 0; bottom: 0; left: 0; display: flex; align-items: center; gap: 10rpx; min-height: 110rpx; padding: 14rpx 16rpx calc(14rpx + env(safe-area-inset-bottom)); background: #fff; border-top: 1rpx solid #dce2e7; box-sizing: border-box; }.composer-icon { width: 62rpx; height: 62rpx; line-height: 62rpx; margin: 0; padding: 0; border-radius: 50%; background: #e9edf1; color: #43505c; font-size: 24rpx; }.composer-input { min-width: 0; height: 72rpx; padding: 0 20rpx; flex: 1; background: #f0f2f4; border-radius: 14rpx; font-size: 25rpx; }.send-button { width: 104rpx; height: 68rpx; line-height: 68rpx; margin: 0; padding: 0; border-radius: 12rpx; background: #1f6feb; color: #fff; font-size: 24rpx; }
