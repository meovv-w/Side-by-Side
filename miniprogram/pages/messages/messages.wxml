<view class="page">
  <view class="filter-bar">
    <view wx:for="{{filters}}" wx:key="key" class="filter {{current === item.key ? 'active' : ''}}" data-key="{{item.key}}" bindtap="change">{{item.label}}</view>
  </view>

  <view wx:if="{{conversations.length === 0}}" class="empty">暂无消息</view>
  <view wx:for="{{conversations}}" wx:key="_id" class="card" bindtap="open" data-id="{{item._id}}">
    <view class="row">
      <view>
        <view class="card-title">{{item.title}}</view>
        <view class="muted">{{item.lastMessage}}</view>
      </view>
      <text wx:if="{{item.unread > 0}}" class="badge">{{item.unread}}</text>
    </view>
  </view>
</view>
