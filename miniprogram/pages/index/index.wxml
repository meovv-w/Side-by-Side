<view class="map-page">
  <view class="status-bar">
    <view class="status-team">
      <view class="status-title">{{currentTrip.teamName || '同路行'}}</view>
      <view class="status-meta">{{currentTrip ? 'Day ' + currentTrip.currentDay : '发现附近同路人'}}</view>
    </view>
    <view class="status-center">{{currentTrip ? '剩余' + currentTrip.remainingDays + '天 · ' + (currentTrip.remainingKm || '--') + 'km' : '未设置行程'}}</view>
    <view class="status-right">
      <view class="status-icon" bindtap="goMessages">消息 <text wx:if="{{stats.unreadCount}}" class="badge">{{stats.unreadCount}}</text></view>
      <view class="weather">{{weather.altitude}}m · {{weather.text}} {{weather.temperature}}°</view>
    </view>
  </view>

  <view class="map-wrap">
    <map
      id="mainMap"
      class="map"
      latitude="{{latitude}}"
      longitude="{{longitude}}"
      scale="9"
      markers="{{markers}}"
      polyline="{{polyline}}"
      enable-traffic="{{activeLayers.traffic}}"
      show-location
      bindmarkertap="onMarkerTap"
      bindlongpress="createTopic"
    ></map>
    <view class="map-tools">
      <button class="tool-button" bindtap="toggleLayerPanel">图层</button>
      <button class="tool-button" bindtap="goSupport">客服</button>
      <button class="tool-button icon-only" bindtap="centerOnMe">◎</button>
    </view>
    <view wx:if="{{energyReminder}}" class="energy-reminder">{{energyReminder.message}}</view>
  </view>

  <view wx:if="{{layerPanelOpen}}" class="layer-panel">
    <view class="row panel-title"><text>地图图层</text><text class="section-link" bindtap="resetLayers">重置默认</text></view>
    <view class="layer-row locked"><view><view class="layer-name">本队信息</view><view class="caption">位置、队友、路线、终点</view></view><switch checked disabled color="#1F6FEB" /></view>
    <view class="layer-row"><view><view class="layer-name">沿途服务</view><view class="caption">加油、餐厅、住宿、维修</view></view><switch checked="{{activeLayers.poi}}" data-key="poi" bindchange="toggleLayer" color="#1F6FEB" /></view>
    <view class="layer-row"><view class="layer-name">拼团优惠</view><switch checked="{{activeLayers.groupbuy}}" data-key="groupbuy" bindchange="toggleLayer" color="#1F6FEB" /></view>
    <view class="layer-row"><view class="layer-name">其他车队与个人</view><switch checked="{{activeLayers.team && activeLayers.driver}}" bindchange="toggleOtherDrivers" color="#1F6FEB" /></view>
    <view class="layer-row"><view class="layer-name">实时路况</view><switch checked="{{activeLayers.traffic}}" data-key="traffic" bindchange="toggleLayer" color="#1F6FEB" /></view>
    <view class="layer-row"><view class="layer-name">地点聊天室</view><switch checked="{{activeLayers.poiChat}}" data-key="poiChat" bindchange="toggleLayer" color="#1F6FEB" /></view>
    <view class="layer-row"><view class="layer-name">安全 POI</view><switch checked="{{activeLayers.safe}}" data-key="safe" bindchange="toggleLayer" color="#1F6FEB" /></view>
    <button wx:if="{{apiMode==='offline'}}" class="text-btn small-btn reset-data" bindtap="resetDemo">恢复初始体验数据</button>
  </view>

  <view wx:if="{{selected}}" class="object-sheet">
    <view class="sheet-head">
      <view>
        <view class="card-title">{{selected.title}}</view>
        <view class="muted">{{selected.subtitle}}</view>
      </view>
      <button class="close-btn" bindtap="closeSelected">×</button>
    </view>
    <view class="object-desc">{{selected.desc}}</view>
    <view wx:if="{{selected.preview}}" class="message-preview">最新消息：{{selected.preview}}</view>
    <view wx:if="{{selected.price}}" class="object-price">车队价 ¥{{selected.price}}</view>
    <view wx:if="{{selected.type === 'poiChatGroup' && selected.topics.length > 1}}" class="topic-choices"><view wx:for="{{selected.topics}}" wx:key="_id" data-id="{{item._id}}" bindtap="openTopic"><view><view class="card-title">{{item.name}}</view><view class="muted">{{item.online}}人参与 · {{item.lastMessage}}</view></view><text>›</text></view></view>
    <view class="object-actions">
      <button wx:if="{{selected.type !== 'poiChatGroup' || selected.topics.length === 1}}" class="secondary-btn small-btn" bindtap="openSelected">查看</button>
      <button wx:if="{{selected.userId || selected.leaderId}}" class="secondary-btn small-btn" bindtap="messageSelected">消息</button>
      <button wx:if="{{selected.type === 'team' || selected.userId || selected.leaderId}}" class="secondary-btn small-btn" bindtap="followSelected">关注</button>
      <button wx:if="{{selected.type === 'poi' || selected.type === 'safe' || selected.type === 'destination' || selected.type === 'groupbuy'}}" class="secondary-btn small-btn" bindtap="navigateSelected">导航</button>
      <button wx:if="{{selected.type === 'traffic'}}" class="secondary-btn small-btn" bindtap="avoidSelected">绕行导航</button>
      <button wx:if="{{selected.phone}}" class="secondary-btn small-btn" bindtap="callSelected">拨号</button>
      <button wx:if="{{selected.type === 'traffic' || selected.type === 'groupbuy'}}" class="primary-btn small-btn" bindtap="shareSelected">发到群聊</button>
    </view>
  </view>

  <view wx:if="{{currentTrip}}" class="current-trip" bindtap="goTrips">
    <view>
      <view class="trip-label">当前行程</view>
      <view class="trip-route">{{currentTrip.from}} → {{currentTrip.to}}</view>
      <view class="caption">{{currentTrip.teamName}} · {{currentTrip.seatJoined}}/{{currentTrip.seatTotal}}车</view>
    </view>
    <view class="trip-side">
      <view class="sharing {{sharingLocation ? 'on' : ''}}" catchtap="toggleSharing">位置 {{sharingLocation ? 'ON' : 'OFF'}}</view>
      <text>›</text>
    </view>
  </view>

  <view class="map-actions">
    <button class="action-item" bindtap="goTrips"><text class="action-symbol route-symbol">＋</text><text>设行程</text></button>
    <button class="action-item" bindtap="reportLocation"><text class="action-symbol location-symbol">⌖</text><text>报位置</text></button>
    <button class="action-item" bindtap="goGroupbuys"><text class="action-symbol deal-symbol">¥</text><text>拼团</text></button>
    <button class="action-item" bindtap="createTopic"><text class="action-symbol topic-symbol">#</text><text>发话题</text></button>
    <button class="action-item" bindtap="reportSafety"><text class="action-symbol traffic-symbol">!</text><text>报路况</text></button>
    <button class="action-item danger-action {{sosHolding?'holding':''}}" bindtouchstart="startSosHold" bindtouchend="cancelSosHold" bindtouchcancel="cancelSosHold"><text class="action-symbol sos-symbol">!</text><text>{{sosHolding?sosProgress+'%':'按住SOS'}}</text></button>
  </view>
</view>
