.profile-page { min-height: 100vh; padding-bottom: 130rpx; background: #f3f5f7; }.profile-cover { padding: 46rpx 30rpx 34rpx; background: #172b4d; color: #fff; text-align: center; }.profile-avatar { width: 124rpx; height: 124rpx; margin: 0 auto 17rpx; background: #dce9ff; color: #1558b0; font-size: 43rpx; }.profile-name { font-size: 38rpx; font-weight: 750; }.profile-bio { max-width: 570rpx; margin: 10rpx auto 15rpx; color: #c4d1df; font-size: 23rpx; }.profile-tags { display: flex; justify-content: center; gap: 9rpx; }.profile-stats { display: grid; grid-template-columns: repeat(4,1fr); padding: 21rpx 10rpx; background: #fff; }.profile-stats view { border-right: 1rpx solid #edf0f2; text-align: center; }.profile-stats view:last-child { border: 0; }.profile-stats text, .profile-stats label { display: block; }.profile-stats text { font-size: 27rpx; font-weight: 700; }.profile-stats label { color: #7b8793; font-size: 19rpx; }.profile-content { min-height: auto; }.vehicle-card .section-title { margin-bottom: 16rpx; }.vehicle-row { display: flex; align-items: center; gap: 16rpx; }.vehicle-icon { display: flex; align-items: center; justify-content: center; width: 80rpx; height: 80rpx; border-radius: 14rpx; background: #eaf2ff; color: #1558b0; font-weight: 700; }.badge-row { display: flex; gap: 14rpx; overflow-x: auto; }.badge-row > view { min-width: 150rpx; padding: 17rpx; background: #fff; border: 1rpx solid #e0e6eb; border-radius: 14rpx; text-align: center; }.medal { display: flex; align-items: center; justify-content: center; width: 64rpx; height: 64rpx; margin: 0 auto 8rpx; border-radius: 50%; background: #fff2cf; color: #a05a00; font-weight: 700; }.badge-row text { font-size: 21rpx; }.trip-row { display: flex; align-items: center; justify-content: space-between; }.profile-footer { position: fixed; right: 0; bottom: 0; left: 0; display: grid; grid-template-columns: 1fr 1.7fr; gap: 12rpx; padding: 17rpx 24rpx calc(17rpx + env(safe-area-inset-bottom)); background: #fff; border-top: 1rpx solid #dfe5ea; }.profile-footer > button:only-child { grid-column: 1 / -1; }
