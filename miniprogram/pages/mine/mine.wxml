<view class="mine-page">
  <view class="profile-band" bindtap="openProfile">
    <image wx:if="{{user.avatar}}" class="avatar large avatar-photo" src="{{user.avatar}}" mode="aspectFill"></image><view wx:else class="avatar large">{{avatarText}}</view>
    <view class="profile-main">
      <view class="profile-name">{{user.nickname || '同路用户'}} <text class="level-badge">Lv.{{user.level || 1}} {{levelTitle}}</text></view>
      <view class="growth-row"><text>同路值 {{user.growth || 0}} / 10000</text><text>{{growthProgress}}%</text></view>
      <view class="progress"><view class="progress-inner" style="width: {{growthProgress}}%"></view></view>
      <view class="trust-row"><text class="certified">{{user.ownerCertStatus === 'approved' ? '车主已认证' : '认证审核中'}}</text><text>信用 {{user.creditScore || '-'}}</text></view>
    </view>
    <text class="chevron">›</text>
  </view>

  <view class="data-overview">
    <view><text>{{user.distanceKm || 0}}</text><label>公里</label></view>
    <view><text>{{user.teamCount || trips.length}}</text><label>同队</label></view>
    <view><text>{{user.companionCount || 0}}</text><label>同行</label></view>
    <view><text>{{social.following || 0}}</text><label>关注</label></view>
    <view><text>{{coupons.length}}</text><label>券</label></view>
  </view>

  <view wx:if="{{currentTrip}}" class="current-trip" bindtap="openTrip">
    <view class="current-icon">行</view>
    <view class="current-main"><view class="card-title">{{currentTrip.from}} → {{currentTrip.to}}</view><view class="muted">{{currentTrip.teamName}} · {{currentTrip.departAt}}</view></view>
    <text>›</text>
  </view>

  <view class="growth-section">
    <view class="growth-heading"><view class="menu-title">同路值明细</view><view class="muted">最近 {{recentGrowthLogs.length}} 条</view></view>
    <view wx:if="{{recentGrowthLogs.length===0}}" class="growth-empty">完成同行、拼团或邀请后会产生同路值记录</view>
    <view wx:for="{{recentGrowthLogs}}" wx:key="_id" class="growth-log-row">
      <view><view class="growth-reason">{{item.reason}}</view><view class="muted">{{item.createdAt}}</view></view>
      <text class="growth-delta {{item.delta<0?'negative':''}}">{{item.deltaText}}</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-title">行程管理</view>
    <view class="menu-grid two">
      <view class="menu-item" bindtap="nav" data-url="/pages/trips/trips"><view class="menu-icon blue">行</view><view><text>我的行程</text><label>当前与历史路线</label></view></view>
      <view class="menu-item" bindtap="nav" data-url="/pages/messages/messages"><view class="menu-icon green">队</view><view><text>我的车队</text><label>群聊永久保留</label></view></view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-title">社交</view>
    <view class="menu-grid two">
      <view class="menu-item" bindtap="nav" data-url="/pages/social/social?tab=following"><view class="menu-icon violet">关</view><view><text>关注与粉丝</text><label>{{social.following || 0}} 关注 · {{social.followers || 0}} 粉丝</label></view></view>
      <view class="menu-item" bindtap="nav" data-url="/pages/social/social?tab=blocked"><view class="menu-icon gray">黑</view><view><text>黑名单</text><label>{{social.blocked || 0}} 人</label></view></view>
    </view>
  </view>

  <view class="safety-section">
    <view class="menu-title safety-title">信任与安全</view>
    <view class="safety-grid">
      <view bindtap="nav" data-url="/pages/certify/certify"><view class="safety-icon">证</view><text>车主认证</text></view>
      <view bindtap="nav" data-url="/pages/settings/settings?section=emergency"><view class="safety-icon">联</view><text>紧急联系人</text></view>
      <view bindtap="nav" data-url="/pages/settings/settings?section=sentinel"><view class="safety-icon">哨</view><text>哨兵模式</text></view>
      <view bindtap="openProfile"><view class="safety-icon">信</view><text>信用档案</text></view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-title">常用功能</view>
    <view class="feature-grid">
      <view bindtap="nav" data-url="/pages/orders/orders"><view class="feature-icon red">单</view><text>我的订单</text></view>
      <view bindtap="nav" data-url="/pages/coupons/coupons"><view class="feature-icon amber">券</view><text>我的券包</text></view>
      <view bindtap="nav" data-url="/pages/badges/badges"><view class="feature-icon violet">章</view><text>勋章墙</text></view>
      <view bindtap="nav" data-url="/pages/invite/invite"><view class="feature-icon blue">邀</view><text>邀请好友</text></view>
      <view bindtap="nav" data-url="/pages/nextTrip/nextTrip"><view class="feature-icon green">下</view><text>下一趟</text></view>
      <view bindtap="nav" data-url="/pages/support/support"><view class="feature-icon cyan">客</view><text>客服中心</text></view>
      <view bindtap="nav" data-url="/pages/settings/settings?section=privacy"><view class="feature-icon gray">隐</view><text>隐私设置</text></view>
      <view bindtap="nav" data-url="/pages/settings/settings"><view class="feature-icon dark">设</view><text>设置</text></view>
    </view>
  </view>
</view>
