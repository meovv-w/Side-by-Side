<view class="page">
  <view class="support-hero"><view><view class="title">客服中心</view><view class="muted">工作日 09:00-21:00 · 紧急情况请拨打 110/120</view></view><view class="support-icon">客</view></view>
  <view class="section-title">常见问题</view>
  <view class="faq-list"><view wx:for="{{faqs}}" wx:key="q" class="faq" data-index="{{index}}" bindtap="faq"><view class="row"><text>{{item.q}}</text><text>{{item.open?'−':'＋'}}</text></view><view wx:if="{{item.open}}" class="faq-answer">{{item.a}}</view></view></view>
  <view class="section-title">提交问题或投诉</view>
  <picker range="{{categories}}" value="{{categoryIndex}}" bindchange="category"><view class="picker-field">{{selectedCategory}}</view></picker>
  <input class="input" placeholder="问题标题" value="{{title}}" data-key="title" bindinput="input"/>
  <textarea class="textarea" placeholder="请描述发生时间、相关订单或车队信息" value="{{content}}" data-key="content" bindinput="input"></textarea>
  <button class="primary-btn submit" bindtap="submit">提交工单</button>
  <view class="section-header"><view class="section-title">我的工单</view><view class="muted">{{tickets.length}} 条</view></view>
  <view wx:if="{{tickets.length===0}}" class="empty">还没有工单</view>
  <view wx:for="{{tickets}}" wx:key="_id" class="card ticket" data-id="{{item._id}}" bindtap="openTicket"><view class="row"><view class="card-title">{{item.title}}</view><text class="tag {{item.status==='resolved'||item.status==='closed'?'success':'warning'}}">{{item.statusText}}</text></view><view class="muted">{{item.category}} · {{item.createdAt}}</view><view wx:if="{{item.lastReply}}" class="reply">客服：{{item.lastReply}}</view><view class="ticket-link">查看对话 ›</view></view>

  <view wx:if="{{ticketOpen}}" class="mask" bindtap="closeTicket"></view>
  <view wx:if="{{ticketOpen}}" class="ticket-sheet">
    <view class="row"><view><view class="title">{{activeTicket.title}}</view><view class="muted">{{activeTicket.statusText}} · {{activeTicket.category}}</view></view><button class="close" bindtap="closeTicket">×</button></view>
    <scroll-view class="ticket-messages" scroll-y>
      <view wx:for="{{activeTicket.messages}}" wx:key="createdAt" class="ticket-message {{item.senderType==='user'?'mine':''}}"><view class="message-sender">{{item.senderText}} · {{item.createdAt}}</view><view class="message-content">{{item.content}}</view></view>
    </scroll-view>
    <view class="ticket-composer"><input placeholder="继续补充问题或回复客服" value="{{replyContent}}" data-key="replyContent" bindinput="input" confirm-type="send" bindconfirm="reply"/><button bindtap="reply">发送</button></view>
  </view>
</view>
