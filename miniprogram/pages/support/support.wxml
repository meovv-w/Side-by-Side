<view class="page">
  <view class="card">
    <view class="card-title">客服与投诉</view>
    <view class="muted">用户端提交后，运营后台可查看并处理。</view>
  </view>
  <input class="input" placeholder="请输入问题或投诉内容" value="{{title}}" bindinput="input" />
  <button class="primary-btn" bindtap="submit">提交工单</button>
</view>
