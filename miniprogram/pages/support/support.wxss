.support-hero{display:flex;align-items:center;justify-content:space-between;padding:28rpx;background:#172b4d;color:#fff;border-radius:16rpx}.support-hero .muted{color:#c5d1df}.support-icon{display:flex;align-items:center;justify-content:center;width:76rpx;height:76rpx;border-radius:16rpx;background:#1f6feb;font-weight:700}.faq-list{overflow:hidden;background:#fff;border:1rpx solid #e0e6eb;border-radius:16rpx}.faq{padding:21rpx;border-bottom:1rpx solid #edf0f2}.faq:last-child{border:0}.faq-answer{margin-top:13rpx;padding-top:13rpx;border-top:1rpx solid #edf0f2;color:#657380;font-size:23rpx;line-height:1.65}.submit{width:100%}.ticket .muted{margin-top:7rpx}.reply{margin-top:14rpx;padding:13rpx;background:#eaf2ff;color:#1558b0;border-radius:10rpx;font-size:23rpx}.ticket-link{margin-top:12rpx;color:#1558b0;font-size:22rpx;text-align:right}.mask{position:fixed;z-index:40;inset:0;background:rgba(18,26,34,.52)}.ticket-sheet{position:fixed;z-index:41;right:0;bottom:0;left:0;display:flex;flex-direction:column;height:78vh;padding:26rpx 22rpx calc(18rpx + env(safe-area-inset-bottom));background:#fff;border-radius:18rpx 18rpx 0 0;box-sizing:border-box}.close{width:58rpx;height:58rpx;line-height:54rpx;margin:0;padding:0;border-radius:50%;background:#edf0f2;color:#53606c;font-size:32rpx}.ticket-messages{flex:1;height:0;margin:20rpx 0;padding:16rpx;background:#f3f5f7;box-sizing:border-box}.ticket-message{max-width:84%;margin-bottom:18rpx}.ticket-message.mine{margin-left:auto;text-align:right}.message-sender{margin-bottom:6rpx;color:#7a8792;font-size:19rpx}.message-content{display:inline-block;padding:14rpx 17rpx;background:#fff;border-radius:8rpx;color:#26323d;text-align:left;word-break:break-all}.ticket-message.mine .message-content{background:#dceaff}.ticket-composer{display:grid;grid-template-columns:minmax(0,1fr) 104rpx;gap:10rpx}.ticket-composer input{height:70rpx;padding:0 18rpx;background:#f0f2f4;border-radius:10rpx}.ticket-composer button{width:104rpx;height:70rpx;line-height:70rpx;margin:0;padding:0;background:#1f6feb;color:#fff;border-radius:10rpx;font-size:23rpx}
