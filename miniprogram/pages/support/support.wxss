.support-hero{display:flex;align-items:center;justify-content:space-between;padding:28rpx;background:#172b4d;color:#fff;border-radius:16rpx}.support-hero .muted{color:#c5d1df}.support-icon{display:flex;align-items:center;justify-content:center;width:76rpx;height:76rpx;border-radius:16rpx;background:#1f6feb;font-weight:700}.faq-list{overflow:hidden;background:#fff;border:1rpx solid #e0e6eb;border-radius:16rpx}.faq{padding:21rpx;border-bottom:1rpx solid #edf0f2}.faq:last-child{border:0}.faq-answer{margin-top:13rpx;padding-top:13rpx;border-top:1rpx solid #edf0f2;color:#657380;font-size:23rpx;line-height:1.65}.submit{width:100%}.ticket .muted{margin-top:7rpx}.reply{margin-top:14rpx;padding:13rpx;background:#eaf2ff;color:#1558b0;border-radius:10rpx;font-size:23rpx}
