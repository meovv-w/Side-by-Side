.trips-page { padding-top: 20rpx; }
.current-card { padding: 26rpx; background: #172b4d; color: #fff; border-radius: 16rpx; box-shadow: 0 10rpx 30rpx rgba(23,43,77,.18); }
.current-head { display: flex; align-items: center; gap: 10rpx; color: #c8d7ec; font-size: 23rpx; }
.live-dot { width: 14rpx; height: 14rpx; border-radius: 50%; background: #2ecc8f; box-shadow: 0 0 0 6rpx rgba(46,204,143,.15); }
.current-status { margin-left: auto; padding: 5rpx 10rpx; border-radius: 8rpx; background: rgba(46,204,143,.17); color: #72e5ba; }
.current-route { margin: 18rpx 0 8rpx; font-size: 36rpx; font-weight: 750; }
.current-meta { color: #c8d7ec; font-size: 23rpx; }
.current-footer { display: flex; justify-content: space-between; margin-top: 22rpx; padding-top: 18rpx; border-top: 1rpx solid rgba(255,255,255,.12); color: #a9c7ff; font-size: 23rpx; }
.empty-current { display: flex; align-items: center; justify-content: space-between; padding: 25rpx; background: #fff; border: 1rpx solid #e0e6eb; border-radius: 16rpx; }
.publish-button { width: 100%; height: 76rpx; line-height: 76rpx; margin: 18rpx 0 4rpx; border: 1rpx dashed #8bb7f3; border-radius: 14rpx; background: #f4f8ff; color: #1f6feb; font-size: 25rpx; }
.publish-plus { margin-right: 5rpx; font-size: 32rpx; }
.trip-card { margin-bottom: 18rpx; padding: 24rpx; background: #fff; border: 1rpx solid #e0e6eb; border-radius: 16rpx; }
.trip-head { display: flex; align-items: center; gap: 14rpx; }
.leader-avatar { display: flex; align-items: center; justify-content: center; width: 70rpx; height: 70rpx; border-radius: 50%; background: #dce9ff; color: #1558b0; font-weight: 700; }
.trip-head-main { min-width: 0; flex: 1; }
.trip-name { overflow: hidden; font-size: 29rpx; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }
.match-rate { color: #657381; font-size: 21rpx; }.match-rate text { display: block; color: #0e7c66; font-size: 31rpx; font-weight: 750; text-align: right; }
.trip-route { margin-top: 22rpx; font-size: 31rpx; font-weight: 700; }
.trip-date { margin-top: 4rpx; color: #657381; font-size: 23rpx; }
.trip-info { display: flex; justify-content: space-between; margin: 18rpx 0 10rpx; padding: 14rpx 0; border-top: 1rpx solid #edf0f2; border-bottom: 1rpx solid #edf0f2; color: #43505c; font-size: 22rpx; }
.trip-tags { color: #1558b0; font-size: 23rpx; }
.equipment { margin-top: 7rpx; color: #0e7c66; font-size: 22rpx; }
.trip-actions { display: grid; grid-template-columns: 1fr 1.35fr; gap: 12rpx; margin-top: 20rpx; }
