.card-title {
  max-width: 500rpx;
}

.filter-bar {
  display: flex;
  gap: 14rpx;
  margin: 22rpx 0 6rpx;
}

.filter {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  background: #ffffff;
  border: 1rpx solid #dce6e2;
  border-radius: 10rpx;
  color: #66736f;
  text-align: center;
  font-size: 25rpx;
}

.filter.active {
  background: #176b5b;
  border-color: #176b5b;
  color: #ffffff;
}
