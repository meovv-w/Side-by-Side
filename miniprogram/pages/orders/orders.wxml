<view class="page">
  <view class="section-title">我的订单</view>
  <view wx:if="{{orders.length === 0}}" class="empty">暂无订单</view>
  <view wx:for="{{orders}}" wx:key="_id" class="card">
    <view class="row">
      <view class="card-title">{{item.title}}</view>
      <text class="tag">{{item.statusText}}</text>
    </view>
    <view class="muted">金额 ¥{{item.amount}} · {{item.createdAt}}</view>
    <view class="code">核销码 {{item.verifyCode}}</view>
  </view>
</view>
