.field-grid{display:grid;grid-template-columns:1fr 1fr;gap:14rpx}.textarea.small{min-height:120rpx}.avatar-picker{display:flex;width:100%;height:98rpx;margin:14rpx 0 20rpx;padding:0 14rpx;align-items:center;gap:16rpx;border:1rpx solid #dfe5ea;border-radius:12rpx;background:#fff;color:#1558b0;font-size:23rpx}.avatar-picker image,.avatar-picker>text{display:flex;width:68rpx;height:68rpx;align-items:center;justify-content:center;border-radius:50%;background:#dce9ff;color:#1558b0;font-weight:700}.avatar-picker label{margin-left:auto}.cert-row,.setting-row{display:flex;align-items:center;justify-content:space-between;min-height:98rpx;padding:8rpx 0;border-bottom:1rpx solid #e5eaee}.save{width:100%;margin-top:28rpx}.reset{width:100%;margin-top:14rpx;background:transparent;color:#c83c32;font-size:24rpx}
