<view class="page settings-page"><view class="section-title">个人资料</view><text class="field-label">昵称</text><input class="input" value="{{user.nickname}}" data-key="nickname" bindinput="input"/><text class="field-label">个人签名</text><textarea class="textarea small" value="{{user.bio}}" data-key="bio" bindinput="input"></textarea><view class="field-grid"><view><text class="field-label">车型</text><input class="input" value="{{user.vehicleModel}}" data-key="vehicleModel" bindinput="input"/></view><view><text class="field-label">车牌号</text><input class="input" value="{{user.vehicleNo}}" data-key="vehicleNo" bindinput="input"/></view></view><view class="cert-row" bindtap="certify"><view><view>车主认证</view><view class="muted">当前状态：{{user.ownerCertStatus}}</view></view><text>›</text></view>
<view class="section-title">隐私与消息</view><view class="setting-row"><view><view>允许附近车队发现我</view><view class="muted">其他车队只看到队长/个人概览</view></view><switch checked="{{settings.discoverable}}" data-key="discoverable" bindchange="toggle" color="#1F6FEB"/></view><view class="setting-row"><view><view>接收车队消息</view><view class="muted">行程与位置提醒</view></view><switch checked="{{settings.allowTeamMessage}}" data-key="allowTeamMessage" bindchange="toggle" color="#1F6FEB"/></view><view class="setting-row"><view><view>接收优惠通知</view><view class="muted">沿途拼团和券到期提醒</view></view><switch checked="{{settings.allowMarketing}}" data-key="allowMarketing" bindchange="toggle" color="#1F6FEB"/></view><view class="setting-row"><view><view>共享实时位置</view><view class="muted">仅当前车队成员可见</view></view><switch checked="{{settings.shareLocation}}" data-key="shareLocation" bindchange="toggle" color="#1F6FEB"/></view>
<view class="section-title">安全</view><view class="setting-row"><view><view>哨兵模式</view><view class="muted">偏离路线或长时间掉队时提醒</view></view><switch checked="{{settings.sentinelMode}}" data-key="sentinelMode" bindchange="toggle" color="#F59E0B"/></view><text class="field-label">紧急联系人</text><input class="input" placeholder="姓名" value="{{settings.emergencyName}}" data-key="emergencyName" bindinput="toggle"/><input class="input" type="number" placeholder="手机号" value="{{settings.emergencyPhone}}" data-key="emergencyPhone" bindinput="toggle"/><button class="primary-btn save" bindtap="save">保存设置</button><button class="reset" bindtap="reset">恢复初始体验数据</button></view>
