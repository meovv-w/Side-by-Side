<view class="page">
  <view class="section-title">我的券包</view>
  <view wx:if="{{coupons.length === 0}}" class="empty">暂无可用券，返回首页点“重置”可恢复演示数据。</view>
  <view wx:for="{{coupons}}" wx:key="_id" class="card coupon">
    <view>
      <view class="card-title">{{item.title}}</view>
      <view class="muted">{{item.type}} · 满 ¥{{item.threshold}} 可用 · {{item.expireAt}} 到期</view>
    </view>
    <view class="coupon-amount">¥{{item.amount}}</view>
  </view>
</view>
