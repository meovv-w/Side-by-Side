<view class="page"><view class="row"><view><view class="title">我的券包</view><view class="muted">支付时自动匹配可用优惠</view></view><view class="coupon-count">{{all.length}} 张</view></view><view class="filter-bar"><view wx:for="{{tabs}}" wx:key="key" class="filter {{current===item.key?'active':''}}" data-key="{{item.key}}" bindtap="change">{{item.label}}</view></view><view wx:if="{{coupons.length===0}}" class="empty">这个分类没有优惠券</view><view wx:for="{{coupons}}" wx:key="_id" class="coupon-card {{current!=='unused'?'disabled':''}}"><view class="coupon-value"><text>¥</text>{{item.amount}}<label>满{{item.threshold}}可用</label></view><view class="coupon-main"><view class="card-title">{{item.title}}</view><view class="muted">{{item.scope}}</view><view class="caption">有效期至 {{item.expireAt}}</view></view><button wx:if="{{current==='unused'}}" class="use-btn" bindtap="use">去使用</button><view wx:else class="coupon-state">{{current==='used'?'已使用':'已过期'}}</view></view></view>
