<view class="page trip-detail with-footer" wx:if="{{trip}}">
  <view class="trip-hero">
    <view class="row"><text class="tag {{trip.status === 'open' ? 'success' : 'neutral'}}">{{trip.statusText}}</text><text wx:if="{{trip.matchRate != null}}" class="match">顺路率 {{trip.matchRate}}%</text></view>
    <view class="hero-title">{{trip.from}} → {{trip.to}}</view>
    <view class="hero-subtitle">{{trip.teamName}} · 队长 {{trip.ownerName}}</view>
    <view class="hero-stats">
      <view><text>{{trip.departAt}}</text><label>出发时间</label></view>
      <view><text>{{trip.days || 1}}天</text><label>预计行程</label></view>
      <view><text>{{trip.seatJoined}}/{{trip.seatTotal}}车</text><label>车队人数</label></view>
    </view>
  </view>

  <map class="map" latitude="{{center.latitude}}" longitude="{{center.longitude}}" scale="8" markers="{{markers}}" polyline="{{polyline}}"></map>

  <view class="card detail-card">
    <view class="section-title">同行计划</view>
    <view class="detail-row"><text>同行深度</text><text>{{trip.depth || '中度'}}同行</text></view>
    <view class="detail-row"><text>沿途打算</text><text>{{trip.plansText || 'AA住宿 · 车辆互助'}}</text></view>
    <view class="detail-row"><text>每日里程</text><text>约 {{trip.dailyKm || 200}}km</text></view>
    <view class="detail-row"><text>人均费用</text><text>约 ¥{{trip.priceShare}}</text></view>
    <view wx:if="{{trip.equipmentText}}" class="safety-note">保障设备：{{trip.equipmentText}}</view>
    <view wx:if="{{trip.note}}" class="trip-note">{{trip.note}}</view>
  </view>

  <view wx:if="{{owned && requests.length}}">
    <view class="section-header"><view class="section-title">入队申请</view><view class="tag warning">{{requests.length}} 待处理</view></view>
    <view wx:for="{{requests}}" wx:key="_id" class="card request-card">
      <view class="row"><view><view class="card-title">{{item.nickname}}</view><view class="muted">{{item.vehicleModel}}</view></view><view class="caption">{{item.createdAt}}</view></view>
      <view class="request-message">{{item.message}}</view>
      <view class="request-actions"><button class="secondary-btn small-btn" data-id="{{item._id}}" data-approve="no" bindtap="review">拒绝</button><button class="primary-btn small-btn" data-id="{{item._id}}" data-approve="yes" bindtap="review">同意加入</button></view>
    </view>
  </view>

  <view wx:if="{{owned && leaveRequests.length}}">
    <view class="section-header"><view class="section-title">退出申请</view><view class="tag warning">{{leaveRequests.length}} 待处理</view></view>
    <view wx:for="{{leaveRequests}}" wx:key="_id" class="card request-card">
      <view class="row"><view><view class="card-title">{{item.nickname}}</view><view class="muted">{{item.vehicleModel || '车队成员'}}</view></view><view class="tag warning">申请退出</view></view>
      <view class="request-message">{{item.leaveReason || '用户主动退出'}}</view>
      <view class="request-actions"><button class="secondary-btn small-btn" data-id="{{item._id}}" data-approve="no" bindtap="reviewLeave">暂不批准</button><button class="primary-btn small-btn" data-id="{{item._id}}" data-approve="yes" bindtap="reviewLeave">同意退出</button></view>
    </view>
  </view>

  <view class="section-header"><view class="section-title">车队成员</view><view class="muted">{{members.length}} 人</view></view>
  <view class="members-card">
    <view wx:for="{{members}}" wx:key="_id" class="member" data-id="{{item.userId}}" bindtap="openMember">
      <view class="avatar small">{{item.avatarText}}</view>
      <view class="member-main"><view>{{item.nickname}} <text wx:if="{{item.role === 'owner'}}" class="tag warning">队长</text><text wx:if="{{item.certified}}" class="tag success">已认证</text><text wx:if="{{item.status === 'leave_pending'}}" class="tag neutral">待退出</text></view><view class="caption">Lv.{{item.level}} · 信用 {{item.creditScore}}</view></view>
      <button wx:if="{{owned && item.role !== 'owner' && item.status !== 'leave_pending'}}" class="member-remove" catchtap="removeMember" data-id="{{item._id}}">移除</button><text wx:else>›</text>
    </view>
  </view>

  <view class="secondary-actions">
    <button class="secondary-btn" bindtap="greetOwner">联系队长</button>
    <button class="secondary-btn" open-type="share">分享行程</button>
    <button class="secondary-btn" bindtap="openGroupbuys">沿途拼团</button>
  </view>

  <view wx:if="{{owned && trip.stage === 'forming'}}" class="owner-actions three"><button class="secondary-btn" bindtap="edit">编辑行程</button><button class="primary-btn" data-action="depart" bindtap="changeState">标记出发</button><button class="danger-outline" data-action="cancel" bindtap="changeState">取消行程</button></view>
  <view wx:elif="{{owned && trip.stage === 'departed'}}" class="owner-actions"><button class="primary-btn" data-action="drive" bindtap="changeState">开始行进</button><button class="secondary-btn" data-action="complete" bindtap="changeState">完成行程</button></view>
  <button wx:elif="{{owned && trip.stage === 'driving'}}" class="primary-btn complete-button" data-action="complete" bindtap="changeState">完成行程</button>
  <button wx:if="{{joined && (!owned || trip.stage === 'completed')}}" class="leave-link" bindtap="leave">{{trip.stage === 'completed' ? '退出永久群聊' : '退出车队'}}</button>

  <view class="footer-actions">
    <button class="secondary-btn" bindtap="greetOwner">先聊聊</button>
    <button wx:if="{{joined}}" class="primary-btn" bindtap="openChat">进入车队群聊</button>
    <button wx:elif="{{requestStatus === 'pending'}}" class="secondary-btn" disabled>等待队长审批</button>
    <button wx:elif="{{trip.status === 'open'}}" class="primary-btn" bindtap="apply">申请加入车队</button>
    <button wx:else class="secondary-btn" disabled>{{trip.status === 'full' ? '车队已满员' : trip.status === 'started' ? '车队已出发' : '行程已结束'}}</button>
  </view>
</view>
<view wx:else class="empty">正在加载行程</view>
