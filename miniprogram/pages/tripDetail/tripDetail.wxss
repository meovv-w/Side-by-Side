.trip-detail { padding-top: 0; }.trip-hero { margin: 0 -24rpx; padding: 30rpx 26rpx; background: #172b4d; color: #fff; }.match { color: #72e5ba; font-size: 24rpx; font-weight: 650; }.hero-title { margin-top: 20rpx; font-size: 39rpx; font-weight: 750; }.hero-subtitle { margin-top: 5rpx; color: #c6d3e2; font-size: 24rpx; }.hero-stats { display: grid; grid-template-columns: 1.5fr .7fr .7fr; margin-top: 26rpx; padding-top: 22rpx; border-top: 1rpx solid rgba(255,255,255,.13); }.hero-stats view { border-right: 1rpx solid rgba(255,255,255,.13); text-align: center; }.hero-stats view:first-child { text-align: left; }.hero-stats view:last-child { border: 0; }.hero-stats text, .hero-stats label { display: block; }.hero-stats text { font-size: 24rpx; font-weight: 650; }.hero-stats label { margin-top: 3rpx; color: #aebed0; font-size: 19rpx; }
.map { width: calc(100% + 48rpx); height: 390rpx; margin: 0 -24rpx 20rpx; }.detail-card { margin-top: 0; }.detail-card .section-title { margin-bottom: 10rpx; }.detail-row { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid #edf0f2; color: #62707d; font-size: 24rpx; }.detail-row text:last-child { max-width: 430rpx; color: #25313c; text-align: right; font-weight: 600; }.safety-note { margin-top: 18rpx; padding: 14rpx; background: #e4f6ef; color: #087f5b; border-radius: 10rpx; font-size: 23rpx; }.trip-note { margin-top: 16rpx; color: #54616d; font-size: 24rpx; line-height: 1.7; }
.request-message { margin: 16rpx 0; padding: 14rpx; background: #f4f6f8; border-radius: 10rpx; color: #44515d; }.request-actions { display: grid; grid-template-columns: 1fr 1.4fr; gap: 12rpx; }.members-card { overflow: hidden; background: #fff; border: 1rpx solid #e2e7ec; border-radius: 16rpx; }.member { display: flex; align-items: center; gap: 15rpx; min-height: 92rpx; padding: 14rpx 20rpx; border-bottom: 1rpx solid #edf0f2; }.member:last-child { border: 0; }.member-main { flex: 1; }.member .tag { margin-left: 8rpx; }.secondary-actions { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10rpx; margin-top: 22rpx; }.secondary-actions button { padding: 0 8rpx; font-size: 23rpx; }.owner-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; margin-top: 16rpx; }.danger-outline { height: 80rpx; line-height: 80rpx; margin: 0; border: 1rpx solid #d94841; border-radius: 16rpx; background: #fff; color: #c83c32; font-size: 27rpx; }.leave-link { width: 100%; margin-top: 15rpx; background: transparent; color: #c83c32; font-size: 24rpx; }
