<view class="poi-page"><view class="room-header"><view><view class="room-name">{{room.name}}</view><view class="room-meta">{{room.location}} · {{room.status==='archived'?'已归档':room.online+'人在线'}}</view></view><button class="follow-button" bindtap="follow">{{room.followed?'已关注':'关注'}}</button></view><scroll-view class="poi-messages" scroll-y scroll-into-view="{{scrollTarget}}"><view wx:if="{{room.status==='archived'}}" class="archive-tip">历史话题仅可浏览，有新事件时由运营重新开放</view><view wx:for="{{messages}}" wx:key="_id" id="{{item.anchor}}" class="poi-message"><view class="avatar small">{{item.avatarText}}</view><view><view class="message-meta">{{item.nickname}} · {{item.createdAt}}</view><view class="message-bubble">{{item.content}}</view></view></view></scroll-view><view wx:if="{{room.status!=='archived'}}" class="poi-composer"><input placeholder="分享这个地点的实时信息" value="{{content}}" bindinput="input" confirm-type="send" bindconfirm="send"/><button bindtap="send">发送</button></view><view wx:else class="archived-footer">该话题已归档，只能查看历史消息</view></view>
