<view class="poi-page">
  <view class="room-header"><view><view class="room-name">{{room.name}}</view><view class="room-meta">{{room.locationName}} · {{room.status==='archived'?'已归档':room.online+'人在线'}}</view></view><button class="follow-button" bindtap="follow">{{room.followed?'已关注':'关注'}}</button></view>
  <scroll-view class="poi-messages" scroll-y scroll-into-view="{{scrollTarget}}">
    <view wx:if="{{room.status==='archived'}}" class="archive-tip">历史话题再次发言后会恢复活跃</view>
    <view wx:for="{{messages}}" wx:key="_id" id="{{item.anchor}}" class="poi-message"><view class="avatar small">{{item.avatarText}}</view><view><view class="message-meta">{{item.nickname}} · {{item.createdAt}}</view><image wx:if="{{item.type==='image'}}" class="message-image" src="{{item.content}}" mode="aspectFill"></image><view wx:else class="message-bubble">{{item.content}}</view></view></view>
  </scroll-view>
  <view class="poi-composer"><button class="poi-image" bindtap="image">＋</button><input placeholder="分享这个地点的实时信息" value="{{content}}" bindinput="input" confirm-type="send" bindconfirm="send"/><button bindtap="send">发送</button></view>
</view>
