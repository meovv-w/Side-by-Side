.poi-page{height:100vh;background:#eef1f4;overflow:hidden}.room-header{display:flex;align-items:center;justify-content:space-between;height:112rpx;padding:0 22rpx;background:#fff;border-bottom:1rpx solid #dfe5ea;box-sizing:border-box}.room-name{max-width:430rpx;overflow:hidden;font-size:28rpx;font-weight:700;text-overflow:ellipsis;white-space:nowrap}.room-meta{color:#6d7b87;font-size:21rpx}.room-actions{display:flex;align-items:center;gap:8rpx}.follow-button{width:120rpx;height:60rpx;line-height:60rpx;margin:0;padding:0;border-radius:12rpx;background:#eaf2ff;color:#1558b0;font-size:22rpx}.topic-menu{width:66rpx;height:60rpx;line-height:50rpx;margin:0;padding:0;background:#eef2f5;color:#53616d;border-radius:10rpx;font-size:23rpx}.poi-messages{height:calc(100vh - 222rpx - env(safe-area-inset-bottom));padding:22rpx;box-sizing:border-box}.archive-tip{margin-bottom:22rpx;padding:11rpx;background:#dfe5ea;color:#65727e;border-radius:8rpx;font-size:20rpx;text-align:center}.poi-message{display:flex;align-items:flex-start;gap:12rpx;margin-bottom:21rpx}.poi-message-main{min-width:0;max-width:78%}.message-meta{margin-bottom:5rpx;color:#7b8894;font-size:19rpx}.reply-quote{margin-bottom:7rpx;padding:9rpx 12rpx;overflow:hidden;border-left:5rpx solid #9cb7d8;background:#e7edf2;color:#536371;font-size:20rpx;text-overflow:ellipsis;white-space:nowrap}.message-bubble{max-width:520rpx;padding:15rpx 18rpx;background:#fff;border-radius:5rpx 15rpx 15rpx 15rpx;word-break:break-all}.message-image{width:320rpx;height:240rpx;border-radius:8rpx;background:#dfe5e9}.poi-composer{position:fixed;right:0;bottom:0;left:0;display:grid;grid-template-columns:68rpx minmax(0,1fr) 110rpx;gap:10rpx;padding:15rpx 18rpx calc(15rpx + env(safe-area-inset-bottom));background:#fff;border-top:1rpx solid #dce2e7}.poi-composer.with-reply{border-top:0}.poi-composer input{height:72rpx;padding:0 18rpx;background:#f0f2f4;border-radius:14rpx}.poi-composer button{width:110rpx;height:68rpx;line-height:68rpx;margin:0;padding:0;border-radius:12rpx;background:#1f6feb;color:#fff;font-size:23rpx}.poi-composer .poi-image{width:68rpx;background:#eef2f5;color:#1558b0;font-size:34rpx}.reply-composer{position:fixed;right:0;bottom:calc(102rpx + env(safe-area-inset-bottom));left:0;display:flex;align-items:center;justify-content:space-between;gap:16rpx;padding:12rpx 22rpx;background:#f5f8fa;border-top:1rpx solid #dce2e7}.reply-composer>view{min-width:0}.reply-composer text{display:block;overflow:hidden;color:#536371;font-size:21rpx;text-overflow:ellipsis;white-space:nowrap}.reply-composer text:first-child{color:#1558b0;font-weight:650}.reply-composer button{width:48rpx;height:48rpx;line-height:44rpx;margin:0;padding:0;border-radius:50%;background:#e4e9ed;color:#536371}.archived-composer{position:fixed;right:0;bottom:0;left:0;height:92rpx;line-height:72rpx;padding-bottom:env(safe-area-inset-bottom);background:#fff;color:#7b8791;text-align:center;border-top:1rpx solid #dce2e7}
