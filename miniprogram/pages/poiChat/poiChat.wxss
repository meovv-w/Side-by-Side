.poi-page{height:100vh;background:#eef1f4;overflow:hidden}.room-header{display:flex;align-items:center;justify-content:space-between;height:112rpx;padding:0 22rpx;background:#fff;border-bottom:1rpx solid #dfe5ea;box-sizing:border-box}.room-name{max-width:520rpx;overflow:hidden;font-size:28rpx;font-weight:700;text-overflow:ellipsis;white-space:nowrap}.room-meta{color:#6d7b87;font-size:21rpx}.follow-button{width:120rpx;height:60rpx;line-height:60rpx;margin:0;padding:0;border-radius:12rpx;background:#eaf2ff;color:#1558b0;font-size:22rpx}.poi-messages{height:calc(100vh - 222rpx - env(safe-area-inset-bottom));padding:22rpx;box-sizing:border-box}.archive-tip{margin-bottom:22rpx;padding:11rpx;background:#dfe5ea;color:#65727e;border-radius:8rpx;font-size:20rpx;text-align:center}.poi-message{display:flex;align-items:flex-start;gap:12rpx;margin-bottom:21rpx}.message-meta{margin-bottom:5rpx;color:#7b8894;font-size:19rpx}.message-bubble{max-width:520rpx;padding:15rpx 18rpx;background:#fff;border-radius:5rpx 15rpx 15rpx 15rpx;word-break:break-all}.message-image{width:320rpx;height:240rpx;border-radius:8rpx;background:#dfe5e9}.poi-composer{position:fixed;right:0;bottom:0;left:0;display:grid;grid-template-columns:68rpx minmax(0,1fr) 110rpx;gap:10rpx;padding:15rpx 18rpx calc(15rpx + env(safe-area-inset-bottom));background:#fff;border-top:1rpx solid #dce2e7}.poi-composer input{height:72rpx;padding:0 18rpx;background:#f0f2f4;border-radius:14rpx}.poi-composer button{width:110rpx;height:68rpx;line-height:68rpx;margin:0;padding:0;border-radius:12rpx;background:#1f6feb;color:#fff;font-size:23rpx}.poi-composer .poi-image{width:68rpx;background:#eef2f5;color:#1558b0;font-size:34rpx}
