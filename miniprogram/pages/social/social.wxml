<view class="page"><view class="filter-bar"><view wx:for="{{tabs}}" wx:key="key" class="filter {{current===item.key?'active':''}}" data-key="{{item.key}}" bindtap="change">{{item.label}}</view></view>
<block wx:if="{{current==='following'}}"><view wx:if="{{following.length===0}}" class="empty">还没有关注的人或车队</view><view wx:for="{{following}}" wx:key="_id" class="social-row"><view class="avatar small">{{item.avatarText}}</view><view class="social-main" data-type="{{item.targetType}}" data-id="{{item.targetId}}" bindtap="open"><view class="card-title">{{item.targetType==='team'?item.target.teamName:item.target.nickname}}</view><view class="muted">{{item.targetType==='team'?(item.target.from+' → '+item.target.to):(item.target.bio||'同路用户')}}</view></view><button class="secondary-btn small-btn" data-type="{{item.targetType}}" data-id="{{item.targetId}}" bindtap="unfollow">已关注</button></view></block>
<block wx:elif="{{current==='followers'}}"><view wx:if="{{followers.length===0}}" class="empty">还没有粉丝</view><view wx:for="{{followers}}" wx:key="_id" class="social-row" data-type="user" data-id="{{item.userId}}" bindtap="open"><view class="avatar small">{{item.avatarText}}</view><view class="social-main"><view class="card-title">{{item.nickname}}</view><view class="muted">Lv.{{item.level}} · 信用 {{item.creditScore}}</view></view><text>›</text></view></block>
<block wx:else><view wx:if="{{blocked.length===0}}" class="empty">黑名单为空</view><view wx:for="{{blocked}}" wx:key="_id" class="social-row"><view class="avatar small">{{item.avatarText}}</view><view class="social-main"><view class="card-title">{{item.nickname}}</view><view class="muted">已阻止对方向你发送私信</view></view><button class="secondary-btn small-btn" data-id="{{item.userId}}" bindtap="unblock">解除</button></view></block></view>
