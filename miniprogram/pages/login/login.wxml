<view class="login-page"><view class="brand"><view class="brand-mark">同</view><view class="brand-name">同路行</view><view class="brand-sub">自驾组队 · 沿途社交 · 车队拼团</view></view><view class="login-panel"><view class="filter-bar"><view class="filter {{mode==='wechat'?'active':''}}" data-mode="wechat" bindtap="mode">微信快捷登录</view><view class="filter {{mode==='phone'?'active':''}}" data-mode="phone" bindtap="mode">手机号登录</view></view><view wx:if="{{mode==='wechat'}}" class="wechat-login"><view class="login-illustration">微</view><view class="muted">授权微信资料后自动注册并登录</view><button class="wechat-button" bindtap="wechat">微信一键登录</button></view><view wx:else><text class="field-label">昵称（首次注册）</text><input class="input" placeholder="怎么称呼你" value="{{form.nickname}}" data-key="nickname" bindinput="input"/><text class="field-label">手机号</text><input class="input" type="number" maxlength="11" placeholder="请输入手机号" value="{{form.phone}}" data-key="phone" bindinput="input"/><view class="code-row"><input class="input" type="number" placeholder="验证码" value="{{form.code}}" data-key="code" bindinput="input"/><button class="secondary-btn" disabled="{{countdown>0}}" bindtap="sendCode">{{countdown>0?countdown+'s':'获取验证码'}}</button></view><button class="primary-btn phone-button" bindtap="phone">登录 / 注册</button></view><view class="agreement">登录即表示同意《用户协议》和《隐私政策》</view></view></view>
