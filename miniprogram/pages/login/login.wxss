.login-page{min-height:100vh;padding:70rpx 34rpx;background:linear-gradient(180deg,#172b4d 0,#172b4d 36%,#f3f5f7 36%);box-sizing:border-box}.brand{text-align:center;color:#fff}.brand-mark{display:flex;align-items:center;justify-content:center;width:108rpx;height:108rpx;margin:0 auto 17rpx;border-radius:24rpx;background:#1f6feb;font-size:48rpx;font-weight:800}.brand-name{font-size:44rpx;font-weight:800}.brand-sub{margin-top:7rpx;color:#c6d3e2;font-size:23rpx}.login-panel{margin-top:50rpx;padding:28rpx;background:#fff;border-radius:16rpx;box-shadow:0 18rpx 50rpx rgba(23,32,42,.16)}.wechat-login{padding:40rpx 0 20rpx;text-align:center}.login-illustration{display:flex;align-items:center;justify-content:center;width:105rpx;height:105rpx;margin:0 auto 18rpx;border-radius:50%;background:#e4f6ef;color:#087f5b;font-size:38rpx;font-weight:750}.wechat-button{width:100%;margin-top:28rpx;background:#0e9f6e;color:#fff;border-radius:16rpx}.code-row{display:grid;grid-template-columns:1.25fr 1fr;gap:12rpx}.code-row button{font-size:24rpx}.phone-button{width:100%}.agreement{margin-top:25rpx;color:#8a96a1;font-size:19rpx;text-align:center}
