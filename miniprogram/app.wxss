page {
  background: #f5f7f6;
  color: #17211f;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.section-title {
  margin: 28rpx 0 16rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e5ece9;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(23, 107, 91, 0.06);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.muted {
  color: #66736f;
  font-size: 24rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
}

.tag {
  display: inline-block;
  margin-right: 10rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #e8f3ef;
  color: #176b5b;
  font-size: 22rpx;
}

.primary-btn,
.secondary-btn,
.danger-btn {
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.primary-btn {
  background: #176b5b;
  color: #ffffff;
}

.secondary-btn {
  background: #e8f3ef;
  color: #176b5b;
}

.danger-btn {
  background: #fff1ea;
  color: #ba4a1c;
}

.input {
  height: 84rpx;
  margin-bottom: 18rpx;
  padding: 0 22rpx;
  background: #ffffff;
  border: 1rpx solid #dce6e2;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.textarea {
  min-height: 150rpx;
  padding: 20rpx 22rpx;
}

.empty {
  padding: 80rpx 20rpx;
  color: #66736f;
  text-align: center;
}

.filter-bar {
  display: flex;
  gap: 14rpx;
  margin: 22rpx 0 6rpx;
}

.filter {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  background: #ffffff;
  border: 1rpx solid #dce6e2;
  border-radius: 10rpx;
  color: #66736f;
  text-align: center;
  font-size: 25rpx;
}

.filter.active {
  background: #176b5b;
  border-color: #176b5b;
  color: #ffffff;
}
